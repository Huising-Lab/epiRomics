# GitHub and CI
^\.github$
^\.githooks$
^codecov\.yml$
^CODE_OF_CONDUCT\.md$

# pkgdown site (built by GitHub Actions on gh-pages)
^_pkgdown\.yml$
^pkgdown$
^docs$

# Build / check artifacts
^Meta$
^doc$
^epiRomics\.BiocCheck$
^epiRomics\.Rcheck$

# Vignette caches and local previews
^vignettes/.*_cache$
^vignettes/built$

# pkgdown-only articles — rendered on the site, not as package vignettes
^vignettes/articles$

# Full-scale data directories — ship only inst/extdata/toy/ in the tarball
^inst/extdata/Histone$
^inst/extdata/ChIP$
^inst/extdata/BED_Annotation$
^inst/extdata/BigWigs$
^inst/extdata/.*\.csv\.bak$

# Test artifacts
^tests/testthat/test-regression\.R$
^tests/testthat/expected_outputs$
^tests/testthat/Rplots\.pdf$

# LICENSE file (R recognises Artistic-2.0 natively)
^LICENSE$

# Editor / IDE cruft (belt-and-suspenders; .gitignore should catch first)
^\.Rproj\.user$
^.*\.Rproj$
^\.vscode$
^\.idea$

# R session / user state
^\.Rhistory$
^\.RData$
^\.Ruserdata$
^\.Rprofile$

# OS junk
^\.DS_Store$
^.*\.DS_Store$
^Thumbs\.db$
^Desktop\.ini$
